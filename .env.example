# Sentinel 4 - Environment Configuration Example
# Copy this to .env and fill in your real credentials

# Groq LLM API Key (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Twilio Configuration (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1987654321

# Server Configuration (Defaults to localhost:3000)
SIM_SERVER_URL=http://localhost:3000

# Email Configuration (for automated repair notifications)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECEIVER=supervisor_email@gmail.com
